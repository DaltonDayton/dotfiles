[user]
    name = Dalton Dayton
    email = {{ .Vars.git_email }}
    signingkey = {{ .Vars.git_signing_key }}
[init]
    defaultBranch = main
[core]
    editor = nvim
    autocrlf = false
    pager = bat
[push]
    autoSetupRemote = true
[pull]
    rebase = true
[gpg]
    format = ssh
[commit]
    gpgsign = true
